<?xml version="1.0"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
    <metadata>
        <id>libbassmix</id>
        <version>2.4.12</version>
        <authors>dmirmilshteyn</authors>
        <owners>dmirmilshteyn</owners>
        <projectUrl>https://github.com/dmirmilshteyn/Native</projectUrl>
        <requireLicenseAcceptance>false</requireLicenseAcceptance>
        <description>Native libraries for bass mix</description>
        <repository type="git" url="https://github.com/dmirmilshteyn/Native"/>
    </metadata>

    <files>
        <file src="runtimes/win-x86/bassmix.dll" target="runtimes/win-x86/native"/>
        <file src="runtimes/win-x64/bassmix.dll" target="runtimes/win-x64/native"/>
        <file src="runtimes/osx-x64/libbassmix.dylib" target="runtimes/osx-x64/native"/>
        <file src="runtimes/osx-arm64/libbassmix.dylib" target="runtimes/osx-arm64/native"/>
        <file src="runtimes/linux-x64/libbassmix.so" target="runtimes/linux-x64/native"/>

        <file src="xcframeworks/bassmix.xcframework/**" target="xcframeworks/bassmix.xcframework"/>
        <file src="build/libbassmix.targets" target="build/libbassmix.targets"/>
        <file src="buildTransitive/libbassmix.targets" target="buildTransitive/libbassmix.targets"/>
    </files>
</package>